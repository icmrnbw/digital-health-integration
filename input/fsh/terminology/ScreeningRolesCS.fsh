CodeSystem: ScreeningRolesCS
Id: screening-roles-cs
Title: "Screening Practitioner Roles CodeSystem"
Description: "Local terminology for staff roles (positions) used in the cervical and breast cancer screening system"
* insert OriginalCodeSystemDraft(screening-roles-cs)

* #his_poliklinika_patronage_nurse "Poliklinika: Patronaj hamshirasi"
  * ^designation[0].language = #ru
  * ^designation[=].value = "Поликлиника: Патронажная сестра"
  * ^designation[+].language = #en
  * ^designation[=].value = "Polyclinic: Patronage nurse"

* #his_poliklinika_registrar "Poliklinika: Registrator"
  * ^designation[0].language = #ru
  * ^designation[=].value = "Поликлиника: Регистратор"
  * ^designation[+].language = #en
  * ^designation[=].value = "Polyclinic: Registrar"

* #his_rmo_obstetrician_gynecologist "RMO: Akusher-ginekolog"
