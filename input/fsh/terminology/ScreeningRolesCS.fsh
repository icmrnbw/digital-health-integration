  * ^designation[=].value = "РМО: Акушер-гинеколог"
  * ^designation[+].language = #en
  * ^designation[=].value = "RMO: Obstetrician-gynecologist"

* #his_rmo_ultrasound_doctor "RMO: UZI shifokori"
